{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/planning.schema.json",
  "title": "企画書コンパイル（planning.compiled.yaml）スキーマ",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "project",
    "source_of_truth"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_file",
        "compiled_at",
        "compiler",
        "version",
        "output_hash"
      ],
      "properties": {
        "source_file": {
          "type": "string",
          "minLength": 1
        },
        "compiled_at": {
          "type": "string",
          "description": "ローカル時刻 'YYYY-MM-DD HH:MM' または ISO-8601。",
          "anyOf": [
            {
              "pattern": "^\\d{4}-\\d{2}-\\d{2} \\d{2}:\\d{2}$"
            },
            {
              "format": "date-time"
            }
          ]
        },
        "compiler": {
          "type": "string",
          "description": "生成者（例：cline / human / script）",
          "minLength": 1
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "output_hash": {
          "type": "string",
          "description": "最終ファイル内容の sha256 (64桁hex)",
          "pattern": "^[0-9a-f]{64}$"
        }
      }
    },
    "project": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "title",
        "purpose",
        "principles",
        "positioning",
        "roadmap",
        "expected_effects",
        "open_questions"
      ],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1
        },
        "background": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "context": {
              "type": "string"
            },
            "summary": {
              "type": "string"
            }
          }
        },
        "problems": {
          "type": "array",
          "description": "現状課題（企画書に書かれている事実のみ）。",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "purpose": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "goals",
            "outcomes"
          ],
          "properties": {
            "goals": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "outcomes": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "principles": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "core_statement",
            "do",
            "dont",
            "human_in_charge"
          ],
          "properties": {
            "core_statement": {
              "type": "string",
              "minLength": 1
            },
            "do": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "dont": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "human_in_charge": {
              "type": "boolean",
              "description": "人が判断主体（自動判定しない）が企画書に明記されている場合 true。"
            }
          }
        },
        "system_structure": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "layers": {
              "type": "array",
              "description": "L1/L2/L3 等の階層モデル（企画書にある範囲で）。",
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": [
                  "level",
                  "name",
                  "scope"
                ],
                "properties": {
                  "level": {
                    "type": "string",
                    "minLength": 1
                  },
                  "name": {
                    "type": "string",
                    "minLength": 1
                  },
                  "scope": {
                    "type": "array",
                    "items": {
                      "type": "string",
                      "minLength": 1
                    }
                  }
                }
              }
            },
            "task_ticket_fields": {
              "type": "array",
              "description": "タスクチケットが保持すべき項目（企画書記載のみ）。",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "auto_generation_allowed": {
              "type": "boolean",
              "description": "自動生成を行わない旨が明記されている場合 false。"
            }
          }
        },
        "status_model": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "statuses": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "abort_requires_reason": {
              "type": "boolean"
            },
            "abort_reason_examples": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "abort_is_official_judgment": {
              "type": "boolean"
            }
          }
        },
        "visualization": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "features": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "flow_diagram": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "generated": {
                  "type": "boolean"
                },
                "includes_abort_branch": {
                  "type": "boolean"
                },
                "produces_quality_history": {
                  "type": "boolean"
                }
              }
            },
            "snapshot": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "session_save": {
                  "type": "boolean"
                },
                "export_formats": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                },
                "intended_use": {
                  "type": "array",
                  "items": {
                    "type": "string",
                    "minLength": 1
                  }
                }
              }
            }
          }
        },
        "ui_quality_points": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "included_in_scope": {
              "type": "boolean"
            },
            "targets": {
              "type": "array",
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "purpose_statement": {
              "type": "string"
            }
          }
        },
        "positioning": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "is_not",
            "is"
          ],
          "properties": {
            "is_not": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1
              }
            },
            "is": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "roadmap": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "phase",
              "scope"
            ],
            "properties": {
              "phase": {
                "type": "integer",
                "minimum": 1
              },
              "scope": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        },
        "expected_effects": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "open_questions": {
          "type": "array",
          "description": "企画書だけでは確定できない点（推測禁止）。",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "source_of_truth": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "citations"
      ],
      "properties": {
        "citations": {
          "type": "array",
          "description": "このコンパイル内容の根拠（章/見出し単位でOK）。",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "section",
              "evidence"
            ],
            "properties": {
              "section": {
                "type": "string",
                "minLength": 1
              },
              "evidence": {
                "type": "string",
                "minLength": 1
              }
            }
          }
        }
      }
    }
  }
}
