{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.local/schemas/planning.index.schema.json",
  "title": "Planning Index YAML Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "planning_index"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "run_id",
        "prompt_id",
        "timestamp",
        "model",
        "output_hash"
      ],
      "properties": {
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "prompt_id": {
          "type": "string",
          "minLength": 1
        },
        "timestamp": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "output_hash": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "planning_index": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "version",
        "title",
        "source",
        "owner",
        "last_updated_date",
        "next_review_date",
        "sections"
      ],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^PLN-DOC-[A-Z0-9_\\-]+$"
        },
        "version": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "path"
          ],
          "properties": {
            "type": {
              "type": "string",
              "enum": [
                "markdown"
              ]
            },
            "path": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "owner": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "name"
          ],
          "properties": {
            "name": {
              "type": "string",
              "minLength": 1
            },
            "team": {
              "type": "string"
            },
            "email": {
              "type": "string"
            }
          }
        },
        "last_updated_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "next_review_date": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "id",
              "file",
              "title"
            ],
            "properties": {
              "id": {
                "type": "string",
                "pattern": "^PLN-SEC-[A-Z0-9_]+-\\d{3}$"
              },
              "file": {
                "type": "string",
                "pattern": "^[0-9]{2}_[a-z0-9_]+\\.yaml$"
              },
              "title": {
                "type": "string",
                "minLength": 1
              },
              "notes": {
                "type": "string"
              }
            }
          }
        }
      }
    }
  }
}